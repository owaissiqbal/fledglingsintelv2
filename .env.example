# Copy to .env and fill in values. Never commit .env.

# Local SQLite database file (relative to repo root)
DATABASE_PATH=./data/fledglings.db

# Where to cache fetched HTML/PDF reports (relative to repo root)
RAW_DOCS_PATH=./data/raw

# Instantly API key (from app.instantly.ai > Settings > Integrations > API Keys)
INSTANTLY_API_KEY=

# Default Instantly campaign or list to push leads into when "Send to Instantly" is clicked
INSTANTLY_DEFAULT_CAMPAIGN_ID=
INSTANTLY_DEFAULT_LIST_ID=

# Concurrency when fetching public reports (keep modest to be polite to gov.uk and isi.net)
FETCH_CONCURRENCY=4

# User agent string used when fetching public reports
# Replace the email with a contact you control
USER_AGENT=Fledglings-ICP-Bot/1.0 (internal tooling; contact: you@fledglings.co)

# Optional: Claude API key powers the "Polish with Claude" button on the
# opportunity detail page. Without it, the button is hidden and everything
# else works as before. Server-side only — never exposed to the browser.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Disable Next.js anonymous telemetry. Already set globally via `next telemetry disable`
# but kept here so it's obvious this project opts out.
NEXT_TELEMETRY_DISABLED=1

# Companies House free API key (HTTP Basic Auth). Used for financial-health
# compliance signals on ITPs (status, accounts overdue, insolvency, charges).
# Register: https://developer.company-information.service.gov.uk/
# Rate limit: 600 req per 5-min window per key — pipeline self-throttles.
COMPANIES_HOUSE_API_KEY=

# Cap on how many ITPs the Companies House compliance scraper will look up
# in one run. Set to 0 to skip Companies House lookups entirely. Defaults
# to 200 — the scraper rolls through the list least-recently-checked first
# so over a few weeks of weekly runs every ITP gets covered.
COMPANIES_HOUSE_BUDGET_PER_RUN=200

# Per-provider Google News scraper budget (top tiers, ordered by score
# desc). Set to 0 to skip. Each provider takes ~2s polite-fetch time
# and pulls one RSS query, so 200 ≈ 7-10 minutes wall clock.
GOOGLE_NEWS_BUDGET_PER_RUN=200

# News LLM extraction budget per run. Most articles are pre-filtered out
# by the trigger-keyword scan (sports, awards, fundraising etc skip the
# LLM call entirely). Only ~20-25% of items reach Claude, so a budget of
# 100 covers ~400 raw articles. Cost is ~£0.001 per article that reaches
# the LLM (Haiku 4.5, ~700 in + ~150 out tokens). Initial bulk run on
# 600 articles ≈ £0.10. Weekly delta runs typically £0.02-0.05.
NEWS_EXTRACTION_BUDGET_PER_RUN=100
